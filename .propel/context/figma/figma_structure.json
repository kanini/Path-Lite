    {
      "id": "page-02",
      "name": "02_Components",
      "description": "Component library with variants",
      "categories": [
        {
          "name": "C/Actions",
          "components": [
            {
              "name": "Button",
              "variants": {
                "type": ["Primary", "Secondary", "Destructive", "Ghost"],
                "state": ["Default", "Hover", "Focus", "Active", "Disabled", "Loading"]
              },
              "specs": {
                "height": "48px",
                "minTouchTarget": "44x44pt",
                "cornerRadius": "8px",
                "typography": "button_label"
              }
            }
          ]
        },
        {
          "name": "C/Inputs",
          "components": [
            {
              "name": "TextField",
              "variants": {
                "state": ["Default", "Focused", "Filled", "Error", "Disabled"]
              },
              "specs": {
                "height": "52px",
                "padding": "12px",
                "cornerRadius": "4px",
                "floatingLabel": true,
                "mandatoryMarker": "*"
              }
            },
            {
              "name": "SelectField",
              "type": "Drill-down picker",
              "specs": {
                "height": "52px",
                "chevron": "16px right",
                "navigatesToFullScreen": true
              }
            },
            {
              "name": "Toggle",
              "usage": "Gender selection",
              "specs": {
                "height": "36px",
                "cornerRadius": "full",
                "type": "Segmented control"
              }
            },
            {
              "name": "SearchBar",
              "specs": {
                "height": "44px",
                "background": "neutral_100",
                "cornerRadius": "8px"
              }
            }
          ]
        },
        {
          "name": "C/Navigation",
          "components": [
            {
              "name": "Header",
              "specs": {
                "height": "56px",
                "background": "white",
                "shadow": "header",
                "zones": ["left (user context)", "center (title)", "right (action)"]
              }
            },
            {
              "name": "LeftNavPanel",
              "specs": {
                "width": "200px (portrait) / 240px (landscape)",
                "background": "neutral_100",
                "sections": ["Hospital", "Patient Summary", "Nav Items"]
              }
            },
            {
              "name": "Tabs",
              "usage": "My Patients / All Patients",
              "specs": {
                "height": "44px",
                "activeIndicator": "bottom border 3px primary"
              }
            }
          ]
        },
        {
          "name": "C/Content",
          "components": [
            {
              "name": "PatientCard",
              "specs": {
                "minHeight": "72px",
                "layout": "vertical stack",
                "elements": ["name", "MRN", "treatment summary", "date", "nurse", "status badge", "3-dot menu"]
              }
            },
            {
              "name": "StatusBadge",
              "variants": ["Not Started", "Tx In Progress", "Received", "Submitted", "Submitted (Amended)"],
              "specs": {
                "typography": "body_sm weight 500",
                "padding": "4px 8px",
                "cornerRadius": "full"
              }
            },
            {
              "name": "FormSection",
              "specs": {
                "background": "white",
                "shadow": "card",
                "cornerRadius": "8px",
                "padding": "16px",
                "fieldGap": "12px",
                "sectionGap": "20px"
              }
            }
          ]
        },
        {
          "name": "C/Feedback",
          "components": [
            {
              "name": "Modal",
              "specs": {
                "backdrop": "overlay_scrim",
                "background": "white",
                "cornerRadius": "12px",
                "shadow": "modal",
                "width": "90% max 480px",
                "padding": "24px"
              }
            },
            {
              "name": "Dialog",
              "specs": {
                "background": "white",
                "cornerRadius": "12px",
                "shadow": "modal",
                "width": "70% max 400px",
                "alignment": "center"
              }
            },
            {
              "name": "AIVoiceIcon",
              "states": ["Inactive (grey)", "Active (blue)", "Listening (animated)"],
              "specs": {
                "size": "48x48pt",
                "transitionDuration": "200ms"
              }
            },
            {
              "name": "ProgressOverlay",
              "specs": {
                "background": "rgba(255,255,255,0.95)",
                "logo": "PATH Lite centered",
                "progressBar": "primary on neutral_300, 4px height"
              }
            },
            {
              "name": "InlineError",
              "specs": {
                "icon": "⚠ 14px warning",
                "typography": "body_sm",
                "position": "below field, 4px gap"
              }
            },
            {
              "name": "HepBHistoryPopover",
              "specs": {
                "width": "260px",
                "maxHeight": "200px scroll",
                "background": "white",
                "shadow": "popover",
                "cornerRadius": "8px"
              }
            },
            {
              "name": "WarningAlert",
              "specs": {
                "background": "warning_bg",
                "borderLeft": "4px warning",
                "icon": "⚠ 20px",
                "padding": "12px 16px",
                "cornerRadius": "4px"
              }
            }
          ]
        },
        {
          "name": "C/Branding",
          "components": [
            {
              "name": "PathLiteLogo",
              "elements": ["Snowflake icon (teal/blue)", "PATH LITE wordmark"],
              "usage": "Login screen, loading overlays"
            },
            {
              "name": "DaVitaWordmark",
              "usage": "Treatment Report Preview top-right"
            }
          ]
        }
      ]
    },
    {
      "id": "page-03",
      "name": "03_Patterns",
      "description": "Reusable layout patterns",
      "patterns": [
        {
          "name": "Auth Form Pattern",
          "usage": "SCR-001 Login",
          "layout": "Centered vertical stack",
          "components": ["Logo", "TextField x2", "Button", "Link"]
        },
        {
          "name": "Split Panel Form Pattern",
          "usage": "SCR-006, 007, 008, 009",
          "layout": "LeftNavPanel (200-240px) + Main content",
          "components": ["LeftNavPanel", "Header", "FormSection", "Buttons"]
        },
        {
          "name": "Search + List Pattern",
          "usage": "SCR-002, 003, 004",
          "layout": "Header + SearchBar + SectionList",
          "components": ["Header", "SearchBar", "SectionList", "ListRow"]
        },
        {
          "name": "Drill-down Picker Pattern",
          "usage": "SCR-006a, 006b, 006c",
          "layout": "Full-screen NavigationHeader + RadioList",
          "components": ["NavigationHeader (back)", "RadioList", "Checkmark"]
        },
        {
          "name": "Error/Empty/Loading States",
          "variants": ["Loading (skeleton/spinner)", "Empty (message + CTA)", "Error (message + retry)"],
          "usage": "All screens"
        }
      ]
    },
    {
      "id": "page-04",
      "name": "04_Screens",
      "description": "All screens with required states",
      "screens": [
        {
          "id": "SCR-001",
          "name": "Login Screen",
          "states": ["Default", "Error", "Loading"],
          "priority": "P0",
          "persona": "Nurse",
          "components": ["PathLiteLogo", "TextField x2", "Button (Primary)", "Link (Need Help?)"]
        },
        {
          "id": "SCR-002",
          "name": "Hospital Selection",
          "states": ["Default", "Loading", "Empty", "Search Active"],
          "priority": "P0",
          "persona": "Nurse",
          "components": ["Header", "SearchBar", "SectionList", "ListRow", "UserMenu"]
        },
        {
          "id": "SCR-003",
          "name": "Patient Dashboard",
          "states": ["Default", "Loading", "Empty", "Error (offline)", "My Patients tab", "All Patients tab"],
          "priority": "P0",
          "persona": "Nurse",
          "components": ["Header", "SearchBar", "Tabs", "SectionList", "PatientCard", "StatusBadge", "ContextMenu", "Dialog"]
        },
        {
          "id": "SCR-004",
          "name": "Patient Recall Search",
          "states": ["Default", "Loading", "Empty", "Results", "Validation"],
          "priority": "P0",
          "persona": "Nurse",
          "components": ["Modal", "TextField x5", "Button (Search, Cancel, Create New)", "ProgressOverlay"]
        },
        {
          "id": "SCR-005",
          "name": "Treatment Type Selection",
          "states": ["Default"],
          "priority": "P0",
          "persona": "Nurse",
          "components": ["Dropdown overlay"]
        },
        {
          "id": "SCR-006",
          "name": "Patient Details Form",
          "states": ["Default", "Loading", "AI Active", "Validation Error", "Session Resume"],
          "priority": "P0",
          "persona": "Nurse",
          "components": ["SplitPanel", "LeftNavPanel", "PatientSummaryCard", "FormSection x2", "TextField x9", "SelectField x5", "Toggle", "DatePicker x3", "AIVoiceIcon"]
        },
        {
          "id": "SCR-006a",
          "name": "Treatment Location Picker",
          "states": ["Default"],
          "priority": "P0",
          "persona": "Nurse",
          "components": ["NavigationHeader", "RadioList"]
        },
        {
          "id": "SCR-006b",
          "name": "HBsAg Picker",
          "states": ["Default"],
          "priority": "P0",
          "persona": "Nurse",
          "components": ["NavigationHeader", "RadioList"]
        },
        {
          "id": "SCR-006c",
          "name": "Source Picker",
          "states": ["Default"],
          "priority": "P0",
          "persona": "Nurse",
          "components": ["NavigationHeader", "RadioList"]
        },
        {
          "id": "SCR-006d",
          "name": "Hep B Change History Popover",
          "states": ["Default"],
          "priority": "P1",
          "persona": "Nurse",
          "components": ["HepBHistoryPopover"]
        },
        {
          "id": "SCR-007",
          "name": "Patient Details Edit Mode",
          "states": ["Default", "Validation Error", "Confirm Change Dialog"],
          "priority": "P0",
          "persona": "Nurse",
          "components": ["Same as SCR-006", "InlineError", "WarningIcon", "Dialog"]
        },
        {
          "id": "SCR-008",
          "name": "Treatment Report Preview",
          "states": ["Default", "Loading"],
          "priority": "P0",
          "persona": "Nurse",
          "components": ["SplitPanel", "LeftNavPanel", "NavigationHeader", "ReportViewer", "DaVitaWordmark"]
        },
        {
          "id": "SCR-009",
          "name": "Review and Submit Screen",
          "states": ["Default", "Submission Loading", "Submission Confirmation"],
          "priority": "P0",
          "persona": "Nurse",
          "components": ["SplitPanel", "LeftNavPanel", "WarningAlert", "Button x2", "Dialog", "ProgressOverlay"]
        },
        {
          "id": "SCR-010",
          "name": "Session Resume Prompt",
          "states": ["Default"],
          "priority": "P0",
          "persona": "Nurse",
          "components": ["Modal", "Button x2 (Resume, Start Over)"]
        },
        {
          "id": "SCR-011",
          "name": "Change Hospital Screen",
          "states": ["Default", "Change Confirmation"],
          "priority": "P1",
          "persona": "Nurse",
          "components": ["NavigationHeader", "PatientSummary", "SearchBar", "RadioList"]
        }
      ]
    },
    {
      "id": "page-05",
      "name": "05_Prototype",
      "description": "Interactive flows wired end-to-end",
      "flows": [
        {
          "id": "FL-001",
          "name": "Nurse Authentication",
          "personas": ["Nurse"],
          "sequence": [
            "SCR-001/Default",
            "Decision: Valid → SCR-002/Default | Invalid → SCR-001/Error"
          ]
        },
        {
          "id": "FL-002",
          "name": "Hospital Selection and Patient Dashboard",
          "personas": ["Nurse"],
          "sequence": [
            "SCR-002/Default",
            "Optional: Search",
            "Tap hospital → SCR-003/Default"
          ]
        },
        {
          "id": "FL-003",
          "name": "New Patient Entry via Recall Search",
          "personas": ["Nurse"],
          "sequence": [
            "SCR-003/Default",
            "Tap Add New → SCR-005/Default",
            "Select Hemodialysis → SCR-004/Default",
            "Enter fields + Search → SCR-004/Loading",
            "Decision: Found → SCR-006/Default (prefilled) | Not Found → SCR-004/Empty → SCR-006/Default (empty)"
          ]
        },
        {
          "id": "FL-004",
          "name": "AI-Driven Patient Data Entry",
          "personas": ["Nurse"],
          "sequence": [
            "SCR-006/Default",
            "AI voice activates → SCR-006/AI Active",
            "Voice responses populate fields",
            "Complete → SCR-009/Default"
          ]
        },
        {
          "id": "FL-005",
          "name": "Form Review and Error Correction",
          "personas": ["Nurse"],
          "sequence": [
            "SCR-009/Default",
            "Tap Review → Validation",
            "Decision: Errors → SCR-007/Validation Error | No Errors → Submit enabled",
            "Correct errors → SCR-009/Default"
          ]
        },
        {
          "id": "FL-006",
          "name": "Report Generation and Final Submission",
          "personas": ["Nurse"],
          "sequence": [
            "SCR-009/Default",
            "Tap View Report → SCR-008/Default",
            "Review → Return to SCR-009",
            "Tap Submit → Dialog → Confirm → SCR-009/Submission Loading → SCR-003/Default (status updated)"
          ]
        },
        {
          "id": "FL-007",
          "name": "Session Resume After Interruption",
          "personas": ["Nurse"],
          "sequence": [
            "SCR-003/Default",
            "Tap incomplete treatment → SCR-010/Default",
            "Decision: Resume → SCR-006/AI Active (partial data) | Start Over → SCR-006/Default"
          ]
        }
      ]
    },
    {
      "id": "page-06",
      "name": "06_Handoff",
      "description": "Developer documentation",
      "sections": [
        {
          "name": "Token Usage Rules",
          "content": "All color, typography, spacing, and radius values MUST use tokens from 01_Foundations. No hard-coded values."
        },
        {
          "name": "Component Usage",
          "content": "Components defined in 02_Components with variants, props, and usage guidelines."
        },
        {
          "name": "Responsive Behavior",
          "breakpoints": {
            "7-inch portrait (600dp)": "Single panel, collapsible left nav",
            "7-inch landscape (960dp)": "Split panel, persistent left nav 200px",
            "12.9-inch portrait (1024dp)": "Split panel, persistent left nav 200px",
            "12.9-inch landscape (1366dp)": "Split panel, persistent left nav 240px"
          }
        },
        {
          "name": "Edge Cases",
          "cases": [
            "Long hospital/patient names: truncate with ellipsis",
            "HBsAg history multiple entries: scrollable popover",
            "MRN-only search: button disabled",
            "AI session auto-close: partial data saved",
            "Report incomplete fields: show dashes or N/A"
          ]
        },
        {
          "name": "Accessibility Notes",
          "requirements": [
            "WCAG 2.2 AA compliance",
            "Color contrast ≥4.5:1 (text), ≥3:1 (UI)",
            "Touch targets ≥44×44pt",
            "Focus states on all interactive elements",
            "ARIA labels for screen readers",
            "Dynamic type support up to 2 stops"
          ]
        },
        {
          "name": "Screen-to-Code Mapping",
          "reference": "figma_spec.md screen IDs (SCR-001 through SCR-011) map to component structure"
        }
      ]
    }
  ]
}
